{
  "position": "top",
  "layer": "top",
  "margin-top": 12,
  "margin-left": 12,
  "margin-right": 12,
  "spacing": 10,
  "height": 52,
  "modules-left": [
    "custom/start",
    "custom/prizrak",
    "hyprland/workspaces"
  ],
  "modules-center": [
    "hyprland/window"
  ],
  "modules-right": [
    "custom/volume",
    "network",
    "custom/keyboard",
    "custom/clock",
    "custom/power"
  ],
  "custom/start": {
    "exec": "~/.config/waybar/scripts/menu-status.sh",
    "return-type": "json",
    "interval": 1,
    "format": "{}",
    "on-click": "~/.config/waybar/scripts/menu-toggle.sh"
  },
  "hyprland/window": {
    "format": "{}",
    "max-length": 56,
    "rewrite": {
      "": "Desktop"
    },
    "separate-outputs": true
  },
  "hyprland/workspaces": {
    "format": "{name}",
    "on-click": "activate",
    "sort-by-number": true,
    "active-only": false,
    "all-outputs": true,
    "persistent-workspaces": {
      "*": 5
    }
  },
  "custom/prizrak": {
    "exec": "~/.config/waybar/scripts/prizrak-status.sh",
    "return-type": "json",
    "interval": 3,
    "format": "{}",
    "on-click": "~/.config/waybar/scripts/prizrak-launch.sh"
  },
  "custom/keyboard": {
    "exec": "~/.config/waybar/scripts/keyboard-layout.sh",
    "return-type": "json",
    "interval": 1,
    "format": "{}",
    "on-click": "~/.config/waybar/scripts/keyboard-layout.sh toggle"
  },
  "custom/clock": {
    "exec": "/home/halflight/.local/bin/waybar-clock.py",
    "return-type": "json",
    "interval": 1,
    "tooltip": false,
    "on-click": "/home/halflight/.local/bin/waybar-clock.py toggle-display",
    "on-click-middle": "/home/halflight/.local/bin/waybar-clock.py today",
    "on-click-right": "/home/halflight/.local/bin/waybar-clock.py toggle-popup",
    "on-scroll-up": "/home/halflight/.local/bin/waybar-clock.py prev",
    "on-scroll-down": "/home/halflight/.local/bin/waybar-clock.py next"
  },
  "custom/volume": {
    "exec": "/home/halflight/.local/bin/waybar-volume.py",
    "return-type": "json",
    "interval": 1,
    "tooltip": false,
    "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "on-click-middle": "wpctl set-volume -l 2.0 @DEFAULT_AUDIO_SINK@ 1.0",
    "on-click-right": "/home/halflight/.local/bin/waybar-volume.py toggle-popup",
    "on-scroll-up": "wpctl set-volume -l 2.0 @DEFAULT_AUDIO_SINK@ 2%+",
    "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 2%-"
  },
  "network": {
    "format-wifi": "{signalStrength}%",
    "format-ethernet": " ",
    "format-linked": " ",
    "format-disconnected": "Offline",
    "tooltip-format-wifi": "{essid}\n{ipaddr}/{cidr}\nSignal: {signalStrength}%",
    "tooltip-format-ethernet": "{ifname}\n{ipaddr}/{cidr}",
    "tooltip-format-disconnected": "Network disconnected",
    "on-click": "nm-connection-editor"
  },
  "custom/power": {
    "format": " ",
    "tooltip": false,
    "on-click": "/home/halflight/.local/bin/wlogout -p layer-shell -m 72 -c 24 -r 24"
  }
}
