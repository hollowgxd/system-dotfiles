{
  "position": "top",
  "layer": "top",
  "margin-top": 12,
  "margin-left": 12,
  "margin-right": 12,
  "spacing": 10,
  "height": 46,
  "modules-left": [
    "custom/start",
    "custom/prizrak",
    "hyprland/workspaces"
  ],
  "modules-center": [
    "hyprland/window"
  ],
  "modules-right": [
    "network",
    "pulseaudio",
    "custom/keyboard",
    "clock",
    "custom/power"
  ],
  "custom/start": {
    "exec": "~/.config/waybar/scripts/menu-status.sh",
    "return-type": "json",
    "interval": 1,
    "format": "{}",
    "on-click": "~/.config/waybar/scripts/menu-toggle.sh"
  },
  "hyprland/window": {
    "format": "{}",
    "max-length": 56,
    "rewrite": {
      "": "Desktop"
    },
    "separate-outputs": true
  },
  "hyprland/workspaces": {
    "format": "{name}",
    "on-click": "activate",
    "sort-by-number": true,
    "active-only": false,
    "all-outputs": true,
    "persistent-workspaces": {
      "*": 5
    }
  },
  "custom/prizrak": {
    "exec": "~/.config/waybar/scripts/prizrak-status.sh",
    "return-type": "json",
    "interval": 3,
    "format": "{}",
    "on-click": "~/.config/waybar/scripts/prizrak-launch.sh"
  },
  "custom/keyboard": {
    "exec": "~/.config/waybar/scripts/keyboard-layout.sh",
    "return-type": "json",
    "interval": 1,
    "format": "{}",
    "on-click": "~/.config/waybar/scripts/keyboard-layout.sh toggle"
  },
  "clock": {
    "locale": "ru_RU.UTF-8",
    "format": "{:%H:%M}",
    "format-alt": "{:%a %d.%m}",
    "tooltip": true,
    "tooltip-format": "<span size='large' weight='700'>{:%A, %d %B %Y}</span>\n<span foreground='#9683b6'>Неделя {:%V} | {:%H:%M} | {:%Z}</span>\n\n<tt>{calendar}</tt>\n\n<span foreground='#9683b6'>Колесо: листать | ПКМ: месяц/год</span>",
    "calendar": {
      "mode": "month",
      "weeks-pos": "right",
      "on-scroll": 1,
      "iso8601": true,
      "format": {
        "months": "<span foreground='#f4ebff' weight='700'>{}</span>",
        "days": "<span foreground='#eadfff'>{}</span>",
        "weeks": "<span foreground='#9683b6'>{}</span>",
        "weekdays": "<span foreground='#c88cff' weight='700'>{}</span>",
        "today": "<span foreground='#ffffff' background='#9158f2' weight='700'>{}</span>"
      }
    },
    "actions": {
      "on-click-right": "mode",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    }
  },
  "network": {
    "format-wifi": "{signalStrength}%",
    "format-ethernet": " ",
    "format-linked": " ",
    "format-disconnected": "Offline",
    "tooltip-format-wifi": "{essid}\n{ipaddr}/{cidr}\nSignal: {signalStrength}%",
    "tooltip-format-ethernet": "{ifname}\n{ipaddr}/{cidr}",
    "tooltip-format-disconnected": "Network disconnected",
    "on-click": "nm-connection-editor"
  },
  "pulseaudio": {
    "format": "{volume}%",
    "format-muted": "0%",
    "tooltip": true,
    "tooltip-format": "Volume {volume}%\nScroll: +/-2%\nLeft click: mute\nMiddle click: 100%\nRight click: mixer",
    "scroll-step": 2,
    "max-volume": 200,
    "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "on-click-middle": "wpctl set-volume -l 2.0 @DEFAULT_AUDIO_SINK@ 1.0",
    "on-click-right": "pavucontrol",
    "on-scroll-up": "wpctl set-volume -l 2.0 @DEFAULT_AUDIO_SINK@ 2%+",
    "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 2%-"
  },
  "custom/power": {
    "format": " ",
    "tooltip": false,
    "on-click": "/home/halflight/.local/bin/wlogout -p layer-shell -m 72 -c 24 -r 24"
  }
}
