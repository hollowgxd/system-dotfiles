{
  "hyprland/workspaces": {
    "format": "{name}",
    "on-click": "activate",
    "sort-by-number": true,
    "active-only": false,
    "all-outputs": true,
    "persistent-workspaces": {
      "*": 5
    }
  },
  "hyprland/window": {
    "format": "{}",
    "max-length": 72,
    "rewrite": {
      "": "Desktop"
    },
    "separate-outputs": true
  },
  "custom/empty": {
    "format": ""
  },
  "custom/appmenu": {
    "format": "Apps",
    "on-click": "~/.config/waybar/scripts/menu-toggle.sh",
    "tooltip": false
  },
  "custom/settings": {
    "format": "пЂ“",
    "on-click": "nwg-look",
    "tooltip": false
  },
  "custom/updates": {
    "format": "у°љ°",
    "tooltip": false
  },
  "custom/filemanager": {
    "format": "пЃј",
    "on-click": "thunar",
    "tooltip": false
  },
  "custom/prizrak": {
    "exec": "~/.config/waybar/scripts/prizrak-status.sh",
    "return-type": "json",
    "interval": 3,
    "format": "{}",
    "on-click": "~/.config/waybar/scripts/prizrak-launch.sh"
  },
  "custom/cliphist": {
    "format": "пѓЄ",
    "on-click": "sleep 0.1 && ~/dotfiles/scripts/cliphist.sh",
    "on-click-right": "sleep 0.1 && ~/dotfiles/scripts/cliphist.sh d",
    "on-click-middle": "sleep 0.1 && ~/dotfiles/scripts/cliphist.sh w",
    "tooltip": false
  },
  "custom/exit": {
    "format": "пЂ‘",
    "on-click": "wlogout -p layer-shell -m 72 -c 24 -r 24",
    "tooltip": false
  },
  "custom/ml4w-welcome": {
    "format": "о¬і",
    "on-click": "~/.local/bin/welcome-scene",
    "tooltip": false
  },
  "clock": {
    "format": "{:%H:%M}",
    "format-alt": "{:%Y-%m-%d}",
    "tooltip-format": "<big>{:%A, %d %B %Y}</big>\n<tt><small>{calendar}</small></tt>"
  },
  "cpu": {
    "format": "п’ј {usage}%",
    "tooltip": false
  },
  "memory": {
    "format": "ої… {}%",
    "tooltip": false
  },
  "disk": {
    "interval": 30,
    "format": "п‚  {percentage_used}%",
    "path": "/",
    "tooltip": false
  },
  "hyprland/language": {
    "format": "{short}"
  },
  "network": {
    "format-wifi": "у°¤Ё {signalStrength}%",
    "format-ethernet": "у°€Ђ Wired",
    "format-linked": "у°€Ђ No IP",
    "format-disconnected": "у°–Є Offline",
    "tooltip-format-wifi": "{essid}\n{ipaddr}/{cidr}\nSignal: {signalStrength}%",
    "tooltip-format-ethernet": "{ifname}\n{ipaddr}/{cidr}",
    "tooltip-format-disconnected": "Network disconnected",
    "on-click": "nm-connection-editor"
  },
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "п‘¦ 0%",
    "format-icons": {
      "default": ["пЂ¦", "пЂ§", "пЂЁ"]
    },
    "tooltip": true,
    "tooltip-format": "Volume {volume}%\nScroll: +/-2%\nLeft click: mute\nMiddle click: 100%\nRight click: mixer",
    "scroll-step": 2,
    "max-volume": 200,
    "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "on-click-middle": "wpctl set-volume -l 2.0 @DEFAULT_AUDIO_SINK@ 1.0",
    "on-click-right": "pavucontrol",
    "on-scroll-up": "wpctl set-volume -l 2.0 @DEFAULT_AUDIO_SINK@ 2%+",
    "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 2%-"
  },
  "bluetooth": {
    "format": "пЉ“ {status}",
    "format-disabled": "",
    "format-off": "",
    "interval": 30,
    "on-click": "blueman-manager",
    "format-no-controller": ""
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "п‡¦ {capacity}%",
    "format-plugged": "п‡¦ {capacity}%",
    "format-alt": "{icon} {time}",
    "format-icons": ["п‰„", "п‰ѓ", "п‰‚", "п‰Ѓ", "п‰Ђ"]
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "tooltip": true,
    "format-icons": {
      "activated": "пЏЃ",
      "deactivated": "пЂЈ"
    },
    "on-click-right": "hyprlock"
  },
  "tray": {
    "icon-size": 18,
    "spacing": 10
  },
  "custom/system": {
    "format": "о‘і",
    "tooltip": false
  },
  "group/settings": {
    "orientation": "horizontal",
    "modules": [
      "custom/settings"
    ]
  },
  "group/quicklinks": {
    "orientation": "horizontal",
    "modules": [
      "custom/prizrak",
      "custom/filemanager"
    ]
  },
  "group/hardware": {
    "orientation": "horizontal",
    "modules": [
      "custom/system",
      "disk",
      "cpu",
      "memory",
      "hyprland/language"
    ]
  }
}
